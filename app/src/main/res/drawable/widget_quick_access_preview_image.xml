<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/widget_preview_outer" />
        </shape>
    </item>

    <item
        android:bottom="8dp"
        android:left="8dp"
        android:right="8dp"
        android:top="8dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/widget_preview_card_fill" />
            <stroke
                android:width="1dp"
                android:color="@color/widget_preview_card_stroke" />
            <corners android:radius="28dp" />
        </shape>
    </item>

    <item
        android:width="72dp"
        android:height="72dp"
        android:gravity="center"
        android:drawable="@drawable/ic_launcher_foreground" />
</layer-list>
